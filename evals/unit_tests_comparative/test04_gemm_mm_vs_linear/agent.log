 category\" in df.columns:\n        return \"op category\"\n    raise ValueError(\n        \"unified_perf_summary needs parent_module or op category for aggregation\"\n    )\n\n\ndef _row_trace2_us(row: pd.Series) -> float:\n    \"\"\"Estimate per-row trace2 kernel time in µs.\n\n    Scales the per-row trace1 time proportionally using\n    ``lca_total_kernel_time_trace2_us / lca_total_kernel_time_trace1_us``.\n    \"\"\"\n    t1 = row.get(_KERNEL_TIME_COL)","isEmpty":false,"exceededLimit":false,"totalLines":404,"fileSize":13741,"path":"/home/AMD/khoffmey/dev/TraceLens/TraceLens/AgenticMode/Standalone/utils/comparative_cumulative_plot.py","readRange":{"startLine":1,"endLine":60},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}}},"model_call_id":"3b861e2d-d946-44d0-b6f3-3218b841c95a-75-otbl","session_id":"ec298410-6d6e-4ff3-a1f8-2136b81261b5","timestamp_ms":1777504883894}
