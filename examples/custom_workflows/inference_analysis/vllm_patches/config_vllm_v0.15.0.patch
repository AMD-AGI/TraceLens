+                        req_id
+                    )
+                    or req_id in new_req_ids
+                ):
+                    c_sk += sk
+                    c_sqsq += sq * sq
+                    c_sqsk += sq * sk
+                else:
+                    g_sk += sk
+                    g_sqsq += sq * sq
+                    g_sqsk += sq * sk
